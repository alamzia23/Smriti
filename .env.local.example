# ---------------------------------------------------------------------------
# Smriti — environment variables (SERVER-ONLY)
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored. NEVER prefix any of these with NEXT_PUBLIC_ —
# these secrets must never reach the browser bundle.
# ---------------------------------------------------------------------------

# --- Cognee Cloud (the memory brain) ---------------------------------------
# Your API base URL. Usually your tenant subdomain (tenant is encoded here).
# Put just the origin, no trailing /api/v1 and no trailing slash.
COGNEE_BASE_URL=https://YOUR-TENANT.aws.cognee.ai

# Your Cognee Cloud API key. Sent as the `X-Api-Key` header, server-side only.
COGNEE_API_KEY=your-cognee-api-key

# Usually already encoded in COGNEE_BASE_URL's subdomain; kept for reference.
COGNEE_TENANT_ID=your-tenant-id

# Usually derived from the API key (GET /api/v1/users/me); kept for reference.
COGNEE_USER_ID=your-user-id

# Dataset name that holds Smriti's incident memory.
COGNEE_DATASET=smriti_incidents

# --- App secrets (generate your own; NOT needed for the Step 0 spike) ------
# HMAC secret used to sign/verify the incident webhook.
WEBHOOK_HMAC_SECRET=change-me-to-a-long-random-string

# Admin secret gating the destructive improve()/forget() endpoints.
ADMIN_SECRET=change-me-to-a-long-random-string

# Shared passphrase gating demo write actions in the UI.
DEMO_PASSPHRASE=change-me

# --- Auth.js (session auth) ------------------------------------------------
# Session-signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-long-random-string

# GitHub OAuth (OPTIONAL). Leave both blank to run with guest sign-in only.
# When set, a "Continue with GitHub" button appears and GitHub users become
# members (may run the admin-gated improve()/forget() ops). Create an OAuth app
# at github.com/settings/developers with callback:
#   http://localhost:3000/api/auth/callback/github  (prod: https://YOUR-DOMAIN/api/auth/callback/github)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
